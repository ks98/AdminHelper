!.env.template

# Server-Datendverzeichnis (bind mount statt Docker-Volume)
/data/

# Agent-Paket-Repo (apt/rpm): vom Updater befuellter bind mount, kein Quellcode
/repo/

# Build-Artefakte
build-deb/
*.deb
*.rpm

# TLS-Zertifikate (auto-generiert oder eigene)
/certs/

# Schluessel-Container — enthalten private Schluessel, NIE committen
# (z.B. der Browser-mTLS-Export adminhelper-browser.p12 aus dem Desktop-Client)
*.p12
*.pfx

# Backup-Tarballs (enthalten Secrets: DB-Dumps, .env, verschluesselter Root-Key)
/backups/

# Playwright
/apps/web/test-results/
/apps/web/playwright-report/
/apps/web/playwright/.cache/

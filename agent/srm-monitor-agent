#!/usr/bin/env python3
"""
srm-monitor-agent — SRM Monitoring Agent

Sammelt System-Metriken und pusht sie an den SRM Monitoring-Service.

Modes:
  --init --url <URL> --api-key <KEY> --server-id <ID>  (Ersteinrichtung)
  (keine Args)                                          (periodischer Push)

Abhaengigkeiten: python3 (>= 3.7), python3-psutil
"""

import argparse
import json
import os
import shutil
import ssl
import subprocess
import sys
import time
from pathlib import Path
from urllib.request import Request, urlopen
from urllib.error import URLError, HTTPError

import psutil

CONF_DIR = Path("/etc/srm")
CONF_FILE = CONF_DIR / "monitor.conf"
LOG_TAG = "srm-monitor-agent"


def log(msg: str) -> None:
    print(f"[{LOG_TAG}] {msg}", file=sys.stderr)


def die(msg: str) -> None:
    log(f"ERROR: {msg}")
    sys.exit(1)


# ---------------------------------------------------------------------------
# System-Metriken sammeln
# ---------------------------------------------------------------------------

def collect_cpu_percent() -> float:
    """CPU-Auslastung (Delta ueber 1 Sekunde)."""
    return psutil.cpu_percent(interval=1)


def collect_memory() -> dict:
    """Speicher-Informationen."""
    mem = psutil.virtual_memory()
    return {
        "memory_percent": round(mem.percent, 1),
        "memory_total_mb": round(mem.total / 1024 / 1024),
        "memory_used_mb": round(mem.used / 1024 / 1024),
    }


def collect_load() -> dict:
    """Load Average."""
    load1, load5, load15 = os.getloadavg()
    return {
        "load_1m": round(load1, 2),
        "load_5m": round(load5, 2),
        "load_15m": round(load15, 2),
    }


def collect_disks() -> list[dict]:
    """Festplatten-Auslastung."""
    disks = []
    for part in psutil.disk_partitions():
        if part.fstype in ("", "squashfs", "tmpfs", "devtmpfs", "overlay"):
            continue
        try:
            usage = psutil.disk_usage(part.mountpoint)
            disks.append({
                "mount": part.mountpoint,
                "percent": round(usage.percent, 1),
                "total_gb": round(usage.total / 1024**3, 1),
                "used_gb": round(usage.used / 1024**3, 1),
            })
        except PermissionError:
            continue
    return disks


def collect_services(service_names: list[str]) -> list[dict]:
    """Prueft ob systemd-Services laufen."""
    services = []
    for name in service_names:
        try:
            result = subprocess.run(
                ["systemctl", "is-active", name],
                capture_output=True, text=True, timeout=5,
            )
            running = result.stdout.strip() == "active"

            pid = None
            if running:
                try:
                    pid_result = subprocess.run(
                        ["systemctl", "show", "-p", "MainPID", name],
                        capture_output=True, text=True, timeout=5,
                    )
                    pid_str = pid_result.stdout.strip().split("=")[-1]
                    pid = int(pid_str) if pid_str.isdigit() and pid_str != "0" else None
                except Exception as exc:
                    log(f"PID-Abfrage fuer '{name}' fehlgeschlagen: {exc}")

            services.append({"name": name, "running": running, "pid": pid})
        except Exception as exc:
            log(f"Service-Status fuer '{name}' nicht ermittelbar: {exc}")
            services.append({"name": name, "running": False, "pid": None})
    return services


def collect_uptime() -> int:
    """Uptime in Sekunden."""
    return int(time.time() - psutil.boot_time())


# ---------------------------------------------------------------------------
# Systemd Health (ersetzt teilweise collect_services)
# ---------------------------------------------------------------------------

def collect_systemd_health() -> dict:
    """Sammelt failed Units und enabled-but-inactive Services."""
    result: dict = {"failed": [], "enabled_inactive": []}

    try:
        out = subprocess.run(
            ["systemctl", "list-units", "--state=failed", "--no-legend", "--plain"],
            capture_output=True, text=True, timeout=10,
        )
        result["failed"] = [
            line.split()[0] for line in out.stdout.strip().splitlines() if line.strip()
        ]
    except Exception as exc:
        log(f"Failed-Units-Abfrage fehlgeschlagen: {exc}")

    try:
        out = subprocess.run(
            ["systemctl", "list-units", "--type=service", "--state=inactive",
             "--no-legend", "--plain"],
            capture_output=True, text=True, timeout=10,
        )
        for line in out.stdout.strip().splitlines():
            unit = line.split()[0] if line.strip() else None
            if not unit:
                continue
            try:
                enabled = subprocess.run(
                    ["systemctl", "is-enabled", unit],
                    capture_output=True, text=True, timeout=3,
                )
                if enabled.stdout.strip() == "enabled":
                    result["enabled_inactive"].append(unit)
            except Exception as exc:
                log(f"is-enabled Pruefung fuer '{unit}' fehlgeschlagen: {exc}")
                continue
    except Exception as exc:
        log(f"Inactive-Services-Abfrage fehlgeschlagen: {exc}")

    return result


# ---------------------------------------------------------------------------
# Plugin: Proxmox
# ---------------------------------------------------------------------------

def _find_last_backup(vmid: int) -> int | None:
    """Findet den ctime-Timestamp des neuesten Backups fuer eine VMID."""
    try:
        storages_out = subprocess.run(
            ["pvesh", "get", "/storage", "--output-format", "json"],
            capture_output=True, text=True, timeout=10,
        )
        storages = json.loads(storages_out.stdout)
    except Exception as exc:
        log(f"Proxmox Storage-Liste fehlgeschlagen: {exc}")
        return None

    newest_ctime: int | None = None
    for storage in storages:
        sid = storage.get("storage", "")
        content = storage.get("content", "")
        if "backup" not in content:
            continue
        try:
            backups_out = subprocess.run(
                ["pvesh", "get", f"/nodes/localhost/storage/{sid}/content",
                 "--content", "backup", "--vmid", str(vmid), "--output-format", "json"],
                capture_output=True, text=True, timeout=15,
            )
            items = json.loads(backups_out.stdout)
            if items:
                ct = max(item.get("ctime", 0) for item in items)
                if newest_ctime is None or ct > newest_ctime:
                    newest_ctime = ct
        except Exception as exc:
            log(f"Backup-Abfrage fuer Storage '{sid}' (VMID {vmid}) fehlgeschlagen: {exc}")
            continue

    return newest_ctime


def collect_proxmox() -> dict | None:
    """Sammelt Proxmox Node-Status und VM/CT Backup-Infos via pvesh CLI."""
    if not shutil.which("pvesh"):
        return None

    result: dict = {"node": None, "vms": []}

    # Node-Status
    try:
        node_name = subprocess.run(
            ["hostname", "-s"], capture_output=True, text=True, timeout=5,
        ).stdout.strip()
        node_out = subprocess.run(
            ["pvesh", "get", f"/nodes/{node_name}/status", "--output-format", "json"],
            capture_output=True, text=True, timeout=15,
        )
        nd = json.loads(node_out.stdout)
        mem = nd.get("memory", {})
        total = mem.get("total", 1) or 1
        result["node"] = {
            "name": node_name,
            "cpu": round(nd.get("cpu", 0) * 100, 1),
            "memory_percent": round(mem.get("used", 0) / total * 100, 1),
        }
    except Exception as exc:
        log(f"Proxmox Node-Status fehlgeschlagen: {exc}")

    # VMs + LXC Container
    try:
        vms_out = subprocess.run(
            ["pvesh", "get", "/cluster/resources", "--type", "vm", "--output-format", "json"],
            capture_output=True, text=True, timeout=15,
        )
        vms = json.loads(vms_out.stdout)
        for vm in vms:
            vmid = vm.get("vmid")
            if vmid is None:
                continue
            vm_info = {
                "vmid": vmid,
                "name": vm.get("name", ""),
                "status": vm.get("status", "unknown"),
                "type": vm.get("type", ""),  # "qemu" oder "lxc"
                "last_backup_ts": _find_last_backup(vmid),
            }
            result["vms"].append(vm_info)
    except Exception as exc:
        log(f"Proxmox VM/CT-Liste fehlgeschlagen: {exc}")

    return result if (result["node"] or result["vms"]) else None


# ---------------------------------------------------------------------------
# Plugin: ZFS
# ---------------------------------------------------------------------------

def collect_zfs() -> dict | None:
    """Sammelt ZFS Pool Health und Kapazitaet."""
    if not shutil.which("zpool"):
        return None

    pools = []
    try:
        out = subprocess.run(
            ["zpool", "list", "-H", "-o", "name,size,alloc,free,cap,health"],
            capture_output=True, text=True, timeout=10,
        )
        for line in out.stdout.strip().splitlines():
            parts = line.split("\t")
            if len(parts) < 6:
                continue
            cap_str = parts[4].rstrip("%")
            pools.append({
                "name": parts[0],
                "size": parts[1],
                "allocated": parts[2],
                "free": parts[3],
                "capacity_percent": int(cap_str) if cap_str.isdigit() else 0,
                "health": parts[5],
            })
    except Exception as exc:
        log(f"ZFS Pool-Liste fehlgeschlagen: {exc}")

    if not pools:
        return None

    result: dict = {"pools": pools}

    # Fehler-Details bei nicht-ONLINE Pools
    if any(p["health"] != "ONLINE" for p in pools):
        try:
            status_out = subprocess.run(
                ["zpool", "status", "-x"],
                capture_output=True, text=True, timeout=10,
            )
            result["errors"] = status_out.stdout.strip()
        except Exception as exc:
            log(f"ZFS Fehler-Details nicht abrufbar: {exc}")

    return result


# ---------------------------------------------------------------------------
# Plugin: Docker
# ---------------------------------------------------------------------------

def collect_docker() -> dict | None:
    """Sammelt Docker Container Status und Restart-Policies."""
    if not shutil.which("docker"):
        return None

    # Pruefen ob Daemon laeuft
    try:
        subprocess.run(
            ["docker", "info"], capture_output=True, timeout=5, check=True,
        )
    except Exception as exc:
        log(f"Docker-Daemon nicht erreichbar: {exc}")
        return None

    containers = []
    try:
        out = subprocess.run(
            ["docker", "ps", "-a", "--format", "{{json .}}"],
            capture_output=True, text=True, timeout=10,
        )
        for line in out.stdout.strip().splitlines():
            if not line.strip():
                continue
            c = json.loads(line)
            container = {
                "id": c.get("ID", ""),
                "name": c.get("Names", ""),
                "image": c.get("Image", ""),
                "state": c.get("State", ""),
                "status": c.get("Status", ""),
                "restart_policy": "",
            }
            try:
                insp = subprocess.run(
                    ["docker", "inspect", "--format",
                     "{{.HostConfig.RestartPolicy.Name}}", container["id"]],
                    capture_output=True, text=True, timeout=5,
                )
                container["restart_policy"] = insp.stdout.strip()
            except Exception as exc:
                log(f"Restart-Policy fuer Container '{container['name']}' nicht ermittelbar: {exc}")
            containers.append(container)
    except Exception as exc:
        log(f"Docker Container-Liste fehlgeschlagen: {exc}")

    return {"containers": containers} if containers else None


def build_report(service_names: list[str]) -> dict:
    """Sammelt alle Metriken und baut den Report."""
    resources = {
        "cpu_percent": collect_cpu_percent(),
    }
    resources.update(collect_memory())
    resources.update(collect_load())
    disks = collect_disks()
    if disks:
        resources["disks"] = disks

    report = {
        "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "resources": resources,
        "uptime_seconds": int(time.time() - psutil.boot_time()),
    }

    # Systemd Health (automatisch)
    systemd = collect_systemd_health()
    if service_names:
        systemd["watched"] = collect_services(service_names)
    report["systemd"] = systemd

    # Legacy: services-Key fuer Rueckwaertskompatibilitaet
    if service_names:
        report["services"] = collect_services(service_names)

    # Auto-detected Plugins
    proxmox = collect_proxmox()
    if proxmox:
        report["proxmox"] = proxmox

    zfs = collect_zfs()
    if zfs:
        report["zfs"] = zfs

    docker = collect_docker()
    if docker:
        report["docker"] = docker

    return report


# ---------------------------------------------------------------------------
# HTTP Push
# ---------------------------------------------------------------------------

def build_ssl_context(cacert: str = "", insecure: bool = False) -> ssl.SSLContext | None:
    """Erstellt einen SSL-Context basierend auf den Optionen."""
    if insecure:
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        return ctx
    if cacert and os.path.isfile(cacert):
        ctx = ssl.create_default_context(cafile=cacert)
        return ctx
    return None


def push_report(url: str, api_key: str, server_id: str, report: dict,
                ssl_context: ssl.SSLContext | None = None) -> bool:
    """Sendet den Report an den Monitoring-Service."""
    endpoint = f"{url.rstrip('/')}/agent/{server_id}/report"
    data = json.dumps(report).encode("utf-8")

    req = Request(endpoint, data=data, method="POST")
    req.add_header("Content-Type", "application/json")
    req.add_header("X-API-Key", api_key)

    try:
        with urlopen(req, timeout=15, context=ssl_context) as resp:
            if resp.status < 300:
                return True
            log(f"Unerwarteter Status: {resp.status}")
            return False
    except HTTPError as exc:
        log(f"HTTP-Fehler: {exc.code} {exc.reason}")
        return False
    except URLError as exc:
        log(f"Verbindungsfehler: {exc.reason}")
        return False
    except Exception as exc:
        log(f"Fehler: {exc}")
        return False


# ---------------------------------------------------------------------------
# Init Mode
# ---------------------------------------------------------------------------

def do_init(url: str, api_key: str, server_id: str, services: str,
            cacert: str = "", insecure: bool = False) -> None:
    """Ersteinrichtung: Config schreiben und systemd aktivieren."""
    url = url.rstrip("/")

    CONF_DIR.mkdir(parents=True, exist_ok=True)

    # CA-Cert kopieren falls angegeben
    stored_cacert = ""
    if cacert:
        if not os.path.isfile(cacert):
            die(f"CA-Zertifikat nicht gefunden: {cacert}")
        dest = CONF_DIR / "ca.crt"
        shutil.copy2(cacert, dest)
        os.chmod(str(dest), 0o644)
        stored_cacert = str(dest)
        log(f"CA-Zertifikat kopiert: {dest}")

    # Config schreiben
    config_lines = [
        f'MONITOR_URL="{url}"',
        f'API_KEY="{api_key}"',
        f'SERVER_ID="{server_id}"',
    ]
    if services:
        config_lines.append(f'SERVICES="{services}"')
    if stored_cacert:
        config_lines.append(f'CACERT="{stored_cacert}"')
    if insecure:
        config_lines.append('INSECURE="1"')
    CONF_FILE.write_text("\n".join(config_lines) + "\n")
    os.chmod(str(CONF_FILE), 0o600)
    log(f"Config geschrieben: {CONF_FILE}")

    # Test-Push
    ssl_ctx = build_ssl_context(stored_cacert, insecure)
    report = build_report(services.split(",") if services else [])
    if push_report(url, api_key, server_id, report, ssl_ctx):
        log("Test-Push erfolgreich")
    else:
        log("WARNUNG: Test-Push fehlgeschlagen — pruefe URL und API-Key")

    # Systemd Units aktivieren (wenn vorhanden)
    for unit in ["srm-monitor-agent.timer"]:
        try:
            subprocess.run(["systemctl", "enable", "--now", unit], check=True, timeout=10)
            log(f"Systemd-Unit aktiviert: {unit}")
        except Exception as exc:
            log(f"Konnte {unit} nicht aktivieren: {exc}")
            log("Bitte manuell aktivieren: systemctl enable --now srm-monitor-agent.timer")


def load_config() -> dict:
    """Liest die Config-Datei."""
    if not CONF_FILE.exists():
        return {}

    config = {}
    for line in CONF_FILE.read_text().strip().split("\n"):
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            key, _, value = line.partition("=")
            config[key.strip()] = value.strip().strip('"')
    return config


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="SRM Monitoring Agent")
    parser.add_argument("--init", action="store_true", help="Ersteinrichtung")
    parser.add_argument("--url", help="Monitoring-Service URL")
    parser.add_argument("--api-key", help="API-Key fuer Authentifizierung")
    parser.add_argument("--server-id", help="Server-ID im SRM")
    parser.add_argument("--services", default="", help="Kommagetrennte Service-Namen (z.B. nginx,frpc,docker)")
    parser.add_argument("--cacert", default="", help="CA-Zertifikat fuer self-signed Server")
    parser.add_argument("--insecure", action="store_true", help="SSL-Verifikation deaktivieren")
    args = parser.parse_args()

    if args.init:
        if not args.url or not args.api_key or not args.server_id:
            die("--init erfordert --url, --api-key und --server-id")
        do_init(args.url, args.api_key, args.server_id, args.services,
                args.cacert, args.insecure)
        return

    # Sync Mode: Config laden und Report pushen
    config = load_config()
    if not config:
        sys.exit(0)

    url = config.get("MONITOR_URL", "")
    api_key = config.get("API_KEY", "")
    server_id = config.get("SERVER_ID", "")

    if not url or not api_key or not server_id:
        die("Config unvollstaendig — bitte erneut mit --init einrichten")

    service_names = [s.strip() for s in config.get("SERVICES", "").split(",") if s.strip()]
    ssl_ctx = build_ssl_context(config.get("CACERT", ""), config.get("INSECURE") == "1")

    report = build_report(service_names)
    if push_report(url, api_key, server_id, report, ssl_ctx):
        log("Report gesendet")
    else:
        log("Report senden fehlgeschlagen")
        sys.exit(1)


if __name__ == "__main__":
    main()

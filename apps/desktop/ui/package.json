    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.3.3",

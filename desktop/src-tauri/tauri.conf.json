{
  "productName": "adminhelper",
  "version": "0.16.0",
  "identifier": "com.adminhelper.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "AdminHelper",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https:"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "publisher": "Kevin Stenzel",
    "homepage": "https://adminhelper.de",
    "shortDescription": "AdminHelper — Remote-Verwaltung mit FRP-Tunneln",
    "longDescription": "Desktop-Client fuer AdminHelper. Verwaltet Remote-Verbindungen (RDP, SSH, VNC, HTTP) ueber sichere FRP-Tunnel mit zentralem Server, PKI-gestuetzter Verschluesselung und integriertem Monitoring.",
    "externalBin": ["binaries/frpc"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

# Docker-Images aus der GitHub Container Registry (ghcr.io).
# Override optional - der Default in docker-compose.yml zeigt bereits hierauf.
# Eigene Version pinnen: ...server:0.24.0 statt :latest
SERVER_IMAGE=ghcr.io/ks98/adminhelper/server:latest
MONITORING_IMAGE=ghcr.io/ks98/adminhelper/monitoring:latest
CA_ISSUER_IMAGE=ghcr.io/ks98/adminhelper/ca-issuer:latest
GATEWAY_IMAGE=ghcr.io/ks98/adminhelper/gateway:latest

# Zeitzone fuer alle Container (Default: Europe/Berlin)
# Liste: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Berlin

# Domain für das TLS-Zertifikat (selbstsigniert wenn kein eigenes in certs/ liegt)
DOMAIN=localhost

# Sicherheitsschlüssel für JWT-Token-Signierung
# Wird durch ./scripts/init-secrets.sh automatisch befuellt.
# Manuell: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Admin-Passwort (optional). Wenn leer ODER 'admin', wird KEIN Default-User
# angelegt. Stattdessen schreibt der Server beim ersten Start einen einmaligen
# Setup-Token nach data/.bootstrap_token und zeigt ihn im WARNING-Log:
#   docker compose logs server | grep -A2 'Setup-Token'
# Damit dann den ersten Admin per
#   POST /api/auth/bootstrap {token, username, password}
# anlegen. Das ist der empfohlene Pfad.
#
# Wenn du ein eigenes Passwort hier setzt (z.B. fuer CI/Test), wird beim
# ersten Start direkt ein 'admin'-User mit diesem Passwort angelegt.
ADMIN_PASSWORD=

# IP-Zugangsbeschränkung (kommagetrennt, leer = kein Filter)
# ALLOWED_IPS=192.168.1.0/24,10.0.0.5,172.16.0.0/12

# Monitoring Service API-Key (Shared Secret AdminHelper <-> Monitoring)
# WICHTIG: Wenn dieser Wert leer bleibt, generieren sich Server- und
# Monitoring-Container UNTERSCHIEDLICHE Keys -> die Monitoring-UI zeigt
# 401-Fehler. Vor dem ersten 'docker compose up' ausfuehren:
#   ./scripts/init-secrets.sh
# Manuell: openssl rand -hex 32
MONITOR_API_KEY=

# PostgreSQL-Passwort (Server- und Monitoring-Container teilen sich einen
# Postgres-Cluster mit zwei DBs: adminhelper, adminhelper_monitor).
# Wird durch ./scripts/init-secrets.sh automatisch befuellt.
# Manuell: openssl rand -hex 32
# Bleibt der Wert leer, weigert sich der Postgres-Container zu starten.
POSTGRES_PASSWORD=

# Passphrase, die den kalten Root-Key der internen PKI at-rest verschluesselt
# (ADR 0001 D7). Wird beim ERSTEN Start des ca-issuer benoetigt, um die
# Hierarchie (Root + Intermediates) zu erzeugen; danach laeuft das Signieren
# unbeaufsichtigt (der Root wird nicht mehr angefasst).
# Wird durch ./scripts/init-secrets.sh automatisch befuellt.
# WICHTIG: getrennt vom verschluesselten Root-Key aufbewahren (Passwortmanager)
# und NICHT in Backups legen - sonst ist die Verschluesselung wertlos.
CA_ROOT_PASSPHRASE=

# Oeffentlicher Port der Enrollment-Plane des Gateways (certless, token-gated).
# Neue Clients (Desktop/Agent/Browser) holen hier ihr erstes Zertifikat.
# ENROLL_PORT=8444

# mTLS-Scharfschaltung. true = ERZWUNGEN (Default): das Gateway verlangt am
# :443-Handshake ein gueltiges Client-Cert (CERT_REQUIRED) UND der Server weist
# geschuetzte Routen ohne gueltigen Cert-Scope mit 403 ab. false = PERMISSIV:
# die Datenebene :443 laesst auch certlose Clients durch (nur Logging). Steuert
# Gateway und Server gemeinsam. scripts/install.sh besorgt dem Erst-Admin sein
# Cert out-of-band und schaltet dann scharf - ein frischer Install ist also ab
# Werk enforced nutzbar. Fuer einen MANUELLEN Erst-Bootstrap (ohne install.sh)
# einmalig auf false setzen, Admin anlegen + enrollen, dann zurueck auf true.
# Details: docs Admin -> Betrieb & Konfiguration.
# MTLS_ENFORCE=true

# Reverse-Proxy: X-Forwarded-For / X-Real-IP auswerten
# TRUST_PROXY_HEADERS=false

# Empfohlen: nur von diesen Proxy-IPs/CIDRs Forwarded-Header akzeptieren
# TRUSTED_PROXIES=172.17.0.1,10.0.0.0/8
